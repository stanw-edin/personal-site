---
import '../styles/global.css';
import { withBase } from '../lib/base';

interface Props {
  title: string;
  description?: string;
  wide?: boolean;
}

const { title, description = 'Data Scientist.', wide = false } = Astro.props;
const path = Astro.url.pathname;

const isActive = (href: string) => {
  const target = withBase(href);
  if (href === '/') return path === target || path === target.replace(/\/$/, '');
  return path.startsWith(target);
};
---

<!doctype html>
<html lang="en">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <meta name="description" content={description} />
    <title>{title} · Stan Wang</title>
    <link rel="preconnect" href="https://fonts.googleapis.com" />
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
    <link
      href="https://fonts.googleapis.com/css2?family=Public+Sans:wght@400;500;600;700;800&family=JetBrains+Mono:wght@400;500;600&display=swap"
      rel="stylesheet"
    />
    <slot name="head" />
  </head>
  <body>
    <nav class="site-nav">
      <div class="wrap">
        <a class="brand" href={withBase('/')}>stan.wang</a>
        <div class="links">
          <a href={withBase('/')} class={isActive('/') ? 'active' : ''}>Home</a>
          <a href={withBase('/cv')} class={isActive('/cv') ? 'active' : ''}>Curriculum Vitae</a>
          <a href={withBase('/blog')} class={isActive('/blog') ? 'active' : ''}>Blog</a>
          <a href={withBase('/photos')} class={isActive('/photos') ? 'active' : ''}>Photos</a>
        </div>
      </div>
    </nav>
    <main>
      <div class={wide ? 'wrap wrap-wide' : 'wrap'}>
        <slot />
      </div>
    </main>
    <footer>
      <div class="wrap">© {new Date().getFullYear()} Stan Wang</div>
    </footer>
  </body>
</html>
