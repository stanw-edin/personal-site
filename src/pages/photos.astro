---
import Layout from '../layouts/Layout.astro';
import { albums } from '../data/albums';
import { withBase } from '../lib/base';

// Parse each album's date once - the comparator below can otherwise end up
// re-parsing the same date strings on every comparison it makes during the
// sort, and the formatted subtitle date would parse it again on top of that.
const albumsWithDate = albums.map((album) => ({ album, parsedDate: new Date(album.date) }));
albumsWithDate.sort((a, b) => b.parsedDate.valueOf() - a.parsedDate.valueOf());

const categories = [...new Set(albumsWithDate.map((a) => a.album.category))].sort();

// Resolve base-prefixed paths once here, so the client script can use the
// strings as-is without needing import.meta.env.
const resolvedAlbums = albumsWithDate.map(({ album, parsedDate }) => ({
  ...album,
  parsedDate,
  cover: withBase(album.photos[0].src),
  photos: album.photos.map((p) => ({ ...p, src: withBase(p.src) })),
}));

// Passed to the client script so the lightbox can navigate prev/next within
// whichever album is currently open, without re-reading the DOM.
const albumPhotosForScript = resolvedAlbums.map((a) => a.photos);

// Passed to the client script to plot map markers - one per album, in the
// same order as the album sections below so marker index lines up with
// albumSections index.
const albumLocationsForScript = resolvedAlbums.map((a) => ({
  title: a.title,
  location: a.location,
  lat: a.lat,
  lng: a.lng,
  cover: a.cover,
}));
---

<Layout
  title="Photos"
  description="A photo journal - albums of memorable days, moments, travels, and events."
  wide
>
  <Fragment slot="head">
    <link rel="stylesheet" href="https://unpkg.com/leaflet@1.9.4/dist/leaflet.css" />
  </Fragment>

  <h1 class="section">Photos</h1>

  {resolvedAlbums.length > 0 && (
    <div class="section">
      <div id="albums-map" class="albums-map"></div>
      <p id="map-error" style="color: var(--text-muted); font-size: 0.85rem; display: none;">
        The map couldn't load - check your connection, or an ad-blocker may be blocking the map provider.
      </p>
      <div class="map-filter-status" id="map-filter-status">
        <span>Showing: <strong id="map-filter-label"></strong></span>
        <button id="map-filter-clear" class="mono" type="button">Clear</button>
      </div>
    </div>
  )}

  {resolvedAlbums.length === 0 && <p style="color: var(--text-muted);">No albums yet.</p>}

  {resolvedAlbums.length > 0 && (
    <div class="category-filters section" id="category-filters">
      <button class="category-pill active" data-category="all" type="button">All</button>
      {categories.map((c) => (
        <button class="category-pill" data-category={c} type="button">{c}</button>
      ))}
    </div>
  )}

  <div class="albums" id="albums">
    {resolvedAlbums.map((album, albumIndex) => (
      <section
        class="card album"
        data-category={album.category}
        data-location={album.location}
        data-album-index={albumIndex}
      >
        <button class="album-header" type="button" aria-expanded="true">
          <img src={album.cover} alt="" class="album-cover" loading="lazy" />
          <div class="album-meta">
            <span class="category-badge">{album.category}</span>
            <h2 class="album-title">{album.title}</h2>
            <p class="album-subtitle mono">
              {album.parsedDate.toLocaleDateString('en-GB', { year: 'numeric', month: 'long', day: 'numeric' })}
              {' · '}
              {album.location}
            </p>
            <p class="album-preview">{album.description}</p>
          </div>
          <span class="album-chevron" aria-hidden="true">&#9662;</span>
        </button>

        <div class="album-content">
          <p class="album-description">{album.description}</p>
          <div class="gallery">
            {album.photos.map((photo, photoIndex) => (
              <button
                class="gallery-item"
                type="button"
                data-album-index={albumIndex}
                data-photo-index={photoIndex}
                aria-label={`Open ${photo.alt}`}
              >
                <img src={photo.src} alt={photo.alt} loading="lazy" />
              </button>
            ))}
          </div>
        </div>
      </section>
    ))}
  </div>

  <p id="no-albums" style="color: var(--text-muted); display: none;">No albums match the current filters.</p>

  <div class="lightbox" id="lightbox" aria-hidden="true">
    <button class="lightbox-close" id="lightbox-close" aria-label="Close">&times;</button>
    <button class="lightbox-nav lightbox-prev" id="lightbox-prev" aria-label="Previous">&larr;</button>
    <img id="lightbox-img" src="" alt="" />
    <button class="lightbox-nav lightbox-next" id="lightbox-next" aria-label="Next">&rarr;</button>
    <p class="mono lightbox-caption" id="lightbox-caption"></p>
  </div>
</Layout>

<script is:inline defer src="https://unpkg.com/leaflet@1.9.4/dist/leaflet.js"></script>

<script define:vars={{ albumPhotos: albumPhotosForScript, albumLocations: albumLocationsForScript }}>
  const albumSections = Array.from(document.querySelectorAll('.album'));
  const albumHeaders = Array.from(document.querySelectorAll('.album-header'));
  const categoryPills = Array.from(document.querySelectorAll('.category-pill'));
  const noAlbums = document.getElementById('no-albums');
  const galleryItems = Array.from(document.querySelectorAll('.gallery-item'));
  const lightbox = document.getElementById('lightbox');
  const lightboxImg = document.getElementById('lightbox-img');
  const lightboxCaption = document.getElementById('lightbox-caption');
  const mapFilterStatus = document.getElementById('map-filter-status');
  const mapFilterLabel = document.getElementById('map-filter-label');
  const mapFilterClear = document.getElementById('map-filter-clear');

  let activeCategory = 'all';
  let activeLocation = 'all';
  let currentAlbum = 0;
  let currentPhoto = 0;

  // Progressive enhancement: the page renders with every album expanded (so
  // it's fully readable with JS disabled). Once JS runs, collapse everything
  // except the most recent album.
  albumSections.forEach((section, i) => {
    if (i !== 0) {
      section.classList.add('collapsed');
      albumHeaders[i]?.setAttribute('aria-expanded', 'false');
    }
  });

  albumHeaders.forEach((header, i) => {
    header.addEventListener('click', () => {
      const section = albumSections[i];
      const collapsed = section.classList.toggle('collapsed');
      header.setAttribute('aria-expanded', String(!collapsed));
    });
  });

  // Shared by the category pills and the map markers - both narrow down the
  // same album list, combined with AND (a category pill plus a map pin both
  // active means "this category AND this location").
  function applyFilters() {
    let visibleCount = 0;
    albumSections.forEach((section) => {
      const matchesCategory = activeCategory === 'all' || section.dataset.category === activeCategory;
      const matchesLocation = activeLocation === 'all' || section.dataset.location === activeLocation;
      const matches = matchesCategory && matchesLocation;
      section.classList.toggle('hidden', !matches);
      if (matches) visibleCount += 1;
    });

    if (noAlbums) noAlbums.style.display = visibleCount === 0 ? 'block' : 'none';

    if (mapFilterStatus) {
      if (activeLocation === 'all') {
        mapFilterStatus.classList.remove('visible');
      } else {
        mapFilterStatus.classList.add('visible');
        if (mapFilterLabel) mapFilterLabel.textContent = activeLocation;
      }
    }
  }

  function setLocationFilter(location) {
    activeLocation = activeLocation === location ? 'all' : location;
    applyFilters();
  }

  categoryPills.forEach((pill) => {
    pill.addEventListener('click', () => {
      categoryPills.forEach((p) => p.classList.remove('active'));
      pill.classList.add('active');
      activeCategory = pill.dataset.category ?? 'all';
      applyFilters();
    });
  });

  mapFilterClear?.addEventListener('click', () => {
    activeLocation = 'all';
    applyFilters();
  });

  // Map - one marker per album, plotted from its lat/lng. Clicking a marker
  // filters the album list below to that location (click again to clear).
  // Wrapped in try/catch and deferred to window 'load' so a Leaflet failure
  // (CDN blocked, ad-blocker, etc.) can't silently kill the lightbox code
  // below it - it's caught, logged, and surfaced via #map-error instead.
  function initAlbumsMap() {
    const mapError = document.getElementById('map-error');
    try {
      if (!window.L) {
        throw new Error('Leaflet failed to load (window.L is undefined) - likely blocked by an ad-blocker or network issue.');
      }
      if (!document.getElementById('albums-map') || albumLocations.length === 0) {
        return;
      }

      const map = L.map('albums-map', { scrollWheelZoom: false });

      // Standard OSM tiles label places in the local script (e.g. Kyoto
      // shows as 京都). CARTO's Voyager tiles use the same underlying OSM
      // data but render labels in Latin/English, so place names stay
      // readable everywhere on the map.
      L.tileLayer('https://{s}.basemaps.cartocdn.com/rastertiles/voyager/{z}/{x}/{y}{r}.png', {
        attribution:
          '&copy; <a href="https://www.openstreetmap.org/copyright">OpenStreetMap</a> contributors &copy; <a href="https://carto.com/attributions">CARTO</a>',
        maxZoom: 18,
      }).addTo(map);

      if (albumLocations.length === 1) {
        map.setView([albumLocations[0].lat, albumLocations[0].lng], 11);
      } else {
        const bounds = L.latLngBounds(albumLocations.map((loc) => [loc.lat, loc.lng]));
        map.fitBounds(bounds, { padding: [40, 40] });
      }

      // Group albums that share (roughly) the same spot into one cluster, so
      // several albums shot in the same place collapse into a single small
      // photo-stack marker instead of overlapping pins. Rounding to 3
      // decimal places groups anything within ~100m. A Map keyed by that
      // rounded coordinate keeps this a single O(n) pass rather than an
      // O(n^2) find-per-album scan.
      const clusterMap = new Map();
      albumLocations.forEach((loc) => {
        const key = `${loc.lat.toFixed(3)},${loc.lng.toFixed(3)}`;
        let cluster = clusterMap.get(key);
        if (!cluster) {
          cluster = { lat: loc.lat, lng: loc.lng, albums: [] };
          clusterMap.set(key, cluster);
        }
        cluster.albums.push(loc);
      });
      const clusters = [...clusterMap.values()];

      function thumbIconHtml(cover, stacked) {
        return `<div class="map-thumb${stacked ? ' stacked' : ''}"><div class="map-thumb-photo"><img src="${cover}" alt="" /></div></div>`;
      }

      function makeThumbIcon(cover, stacked, size) {
        return L.divIcon({
          html: thumbIconHtml(cover, stacked),
          className: 'map-thumb-icon',
          iconSize: [size, size],
          iconAnchor: [size / 2, size / 2],
        });
      }

      clusters.forEach((cluster) => {
        const count = cluster.albums.length;
        const stackMarker = L.marker([cluster.lat, cluster.lng], {
          icon: makeThumbIcon(cluster.albums[0].cover, count > 1, 40),
          zIndexOffset: 1000,
        }).addTo(map);

        if (count === 1) {
          const loc = cluster.albums[0];
          stackMarker.bindPopup(`<strong>${loc.title}</strong><br>${loc.location}`);
          stackMarker.on('click', () => setLocationFilter(loc.location));
          return;
        }

        // Count badge, appended after Leaflet places the icon in the DOM.
        const el = stackMarker.getElement();
        if (el) {
          const badge = document.createElement('span');
          badge.className = 'map-thumb-count';
          badge.textContent = String(count);
          el.querySelector('.map-thumb')?.appendChild(badge);
        }

        let expanded = false;
        let childMarkers = [];

        function collapse() {
          childMarkers.forEach((m) => map.removeLayer(m));
          childMarkers = [];
          expanded = false;
        }

        function expand() {
          const center = map.latLngToContainerPoint([cluster.lat, cluster.lng]);
          const radius = 34;
          childMarkers = cluster.albums.map((loc, i) => {
            const angle = (2 * Math.PI * i) / cluster.albums.length - Math.PI / 2;
            const point = L.point(center.x + radius * Math.cos(angle), center.y + radius * Math.sin(angle));
            const latlng = map.containerPointToLatLng(point);
            const marker = L.marker(latlng, { icon: makeThumbIcon(loc.cover, false, 30) }).addTo(map);
            marker.bindPopup(`<strong>${loc.title}</strong><br>${loc.location}`);
            marker.on('click', () => setLocationFilter(loc.location));
            return marker;
          });
          expanded = true;
        }

        stackMarker.on('click', () => {
          if (expanded) {
            collapse();
          } else {
            expand();
          }
        });

        // Positions are computed in screen space, so they go stale on
        // zoom - simplest correct behaviour is to collapse rather than
        // track and reposition every child marker.
        map.on('zoomstart', collapse);
      });

      // Leaflet sizes itself from the container's dimensions at creation
      // time - if the container was hidden or mid-layout, force a recalc.
      setTimeout(() => map.invalidateSize(), 100);
    } catch (err) {
      console.error('Albums map failed to initialize:', err);
      if (mapError) mapError.style.display = 'block';
    }
  }

  if (document.readyState === 'complete') {
    initAlbumsMap();
  } else {
    window.addEventListener('load', initAlbumsMap);
  }

  function openLightbox(albumIndex, photoIndex) {
    currentAlbum = albumIndex;
    currentPhoto = photoIndex;
    renderLightbox();
    lightbox.classList.add('open');
    lightbox.setAttribute('aria-hidden', 'false');
  }

  function closeLightbox() {
    lightbox.classList.remove('open');
    lightbox.setAttribute('aria-hidden', 'true');
  }

  function renderLightbox() {
    const photo = albumPhotos[currentAlbum][currentPhoto];
    lightboxImg.src = photo.src;
    lightboxImg.alt = photo.alt;
    lightboxCaption.textContent = photo.caption ?? '';
  }

  function nextPhoto() {
    const photos = albumPhotos[currentAlbum];
    currentPhoto = (currentPhoto + 1) % photos.length;
    renderLightbox();
  }

  function prevPhoto() {
    const photos = albumPhotos[currentAlbum];
    currentPhoto = (currentPhoto - 1 + photos.length) % photos.length;
    renderLightbox();
  }

  galleryItems.forEach((el) => {
    el.addEventListener('click', () => {
      openLightbox(Number(el.dataset.albumIndex), Number(el.dataset.photoIndex));
    });
  });

  document.getElementById('lightbox-close')?.addEventListener('click', closeLightbox);
  document.getElementById('lightbox-next')?.addEventListener('click', nextPhoto);
  document.getElementById('lightbox-prev')?.addEventListener('click', prevPhoto);
  lightbox?.addEventListener('click', (e) => {
    if (e.target === lightbox) closeLightbox();
  });
  document.addEventListener('keydown', (e) => {
    if (!lightbox.classList.contains('open')) return;
    if (e.key === 'Escape') closeLightbox();
    if (e.key === 'ArrowRight') nextPhoto();
    if (e.key === 'ArrowLeft') prevPhoto();
  });
</script>

<style>
  .albums-map {
    width: 100%;
    height: 360px;
    border-radius: 10px;
    overflow: hidden;
    box-shadow: 0 1px 2px rgba(16, 24, 40, 0.06), 0 1px 3px rgba(16, 24, 40, 0.08);
  }

  /* Photo-thumbnail map markers, replacing Leaflet's default pin. */
  :global(.map-thumb-icon) {
    background: transparent;
    border: none;
  }

  :global(.map-thumb) {
    position: relative;
    width: 100%;
    height: 100%;
    /* Deliberately NOT overflow: hidden here - the count badge is
       positioned outside this box and must not be clipped. Rounding and
       clipping of the photo itself happens on .map-thumb-photo instead. */
    cursor: pointer;
  }

  :global(.map-thumb-photo) {
    width: 100%;
    height: 100%;
    border-radius: 8px;
    overflow: hidden;
    border: 2px solid #fff;
    box-shadow: 0 2px 6px rgba(16, 24, 40, 0.35);
  }

  :global(.map-thumb img) {
    width: 100%;
    height: 100%;
    object-fit: cover;
    display: block;
  }

  /* Extra layers behind the top thumbnail suggest a small stack of photos
     when a cluster holds more than one album. */
  :global(.map-thumb.stacked::before),
  :global(.map-thumb.stacked::after) {
    content: '';
    position: absolute;
    inset: 0;
    border-radius: 8px;
    background: #fff;
    border: 2px solid #fff;
    box-shadow: 0 2px 4px rgba(16, 24, 40, 0.25);
  }

  :global(.map-thumb.stacked::before) {
    transform: translateY(5px);
    z-index: -1;
  }

  :global(.map-thumb.stacked::after) {
    transform: translateY(10px);
    z-index: -2;
  }

  :global(.map-thumb-count) {
    position: absolute;
    top: -9px;
    right: -9px;
    min-width: 22px;
    height: 22px;
    padding: 0 5px;
    display: flex;
    align-items: center;
    justify-content: center;
    background: var(--accent);
    color: #fff;
    font-family: 'JetBrains Mono', monospace;
    font-size: 12px;
    font-weight: 700;
    line-height: 1;
    border-radius: 999px;
    border: 2px solid #fff;
    box-shadow: 0 1px 3px rgba(16, 24, 40, 0.5);
  }

  .map-filter-status {
    display: none;
    align-items: center;
    gap: 0.75rem;
    margin-top: var(--space-2);
    font-size: 0.9rem;
    color: var(--text-muted);
  }

  .map-filter-status.visible {
    display: flex;
  }

  #map-filter-clear {
    font-size: 0.8rem;
    background: none;
    border: 1px solid var(--border);
    color: var(--text);
    border-radius: 999px;
    padding: 0.2rem 0.7rem;
    cursor: pointer;
  }

  #map-filter-clear:hover {
    border-color: var(--accent);
    color: var(--accent);
  }

  .albums {
    display: flex;
    flex-direction: column;
    gap: var(--space-3);
  }

  .album {
    padding: 0;
    overflow: hidden;
  }

  .album.hidden {
    display: none;
  }

  .album-header {
    display: flex;
    align-items: center;
    gap: var(--space-3);
    width: 100%;
    padding: var(--space-4);
    background: none;
    border: none;
    cursor: pointer;
    text-align: left;
    font: inherit;
    color: inherit;
  }

  /* Fixed square, vertically centred next to the text block. Matching the
     text block's actual height (badge + title + date/location + preview -
     four lines) made the image too large; a fixed size reads better. */
  .album-cover {
    flex-shrink: 0;
    width: 110px;
    height: 110px;
    border-radius: 8px;
    object-fit: cover;
  }

  .album-meta {
    flex: 1;
    min-width: 0;
  }

  .album-title {
    margin: 0.3rem 0 0.15rem;
  }

  .album-subtitle {
    margin: 0;
    color: var(--text-muted);
    font-size: 0.85rem;
  }

  /* One-line teaser of the description, shown only while the album is
     collapsed - gives a hint of what's inside before expanding, and gets
     out of the way once the full description is visible below. */
  .album-preview {
    display: none;
    margin: 0.4rem 0 0;
    color: var(--text-muted);
    font-size: 0.9rem;
    white-space: nowrap;
    overflow: hidden;
    text-overflow: ellipsis;
    text-align: left;
  }

  .album.collapsed .album-preview {
    display: block;
  }

  .album-chevron {
    flex-shrink: 0;
    align-self: center;
    color: var(--text-muted);
    font-size: 1rem;
    transition: transform 0.15s ease;
  }

  .album.collapsed .album-chevron {
    transform: rotate(-90deg);
  }

  .album-content {
    padding: 0 var(--space-4) var(--space-4);
    border-top: 1px solid var(--border);
    margin-top: 0;
    padding-top: var(--space-4);
  }

  .album.collapsed .album-content {
    display: none;
  }

  .album-description {
    color: var(--text-muted);
    margin: 0 0 var(--space-3);
  }

  .gallery {
    display: grid;
    grid-template-columns: repeat(auto-fill, minmax(220px, 1fr));
    gap: var(--space-3);
  }

  .gallery-item {
    padding: 0;
    border: 1px solid var(--border);
    border-radius: 10px;
    overflow: hidden;
    background: none;
    cursor: pointer;
    line-height: 0;
    transition: border-color 0.15s ease;
  }

  .gallery-item:hover {
    border-color: var(--accent);
  }

  .gallery-item img {
    width: 100%;
    height: 160px;
    object-fit: cover;
    display: block;
    transition: transform 0.2s ease;
  }

  .gallery-item:hover img {
    transform: scale(1.03);
  }

  .lightbox {
    display: none;
    position: fixed;
    inset: 0;
    background: rgba(10, 14, 20, 0.95);
    align-items: center;
    justify-content: center;
    flex-direction: column;
    z-index: 50;
  }

  .lightbox.open {
    display: flex;
  }

  .lightbox img {
    max-width: 85vw;
    max-height: 75vh;
    border-radius: 8px;
    border: 1px solid rgba(255, 255, 255, 0.2);
  }

  .lightbox-caption {
    color: rgba(255, 255, 255, 0.75);
    margin-top: 1rem;
  }

  .lightbox-close,
  .lightbox-nav {
    position: absolute;
    background: none;
    border: none;
    color: #fff;
    font-size: 2rem;
    cursor: pointer;
  }

  .lightbox-close {
    top: 1.5rem;
    right: 2rem;
  }

  .lightbox-prev {
    left: 2rem;
    top: 50%;
    transform: translateY(-50%);
  }

  .lightbox-next {
    right: 2rem;
    top: 50%;
    transform: translateY(-50%);
  }
</style>
