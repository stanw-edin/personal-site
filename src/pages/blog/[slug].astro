---
import Layout from '../../layouts/Layout.astro';
import { getCollection, render } from 'astro:content';
import { withBase } from '../../lib/base';

export async function getStaticPaths() {
  const posts = await getCollection('blog', ({ data }) => !data.draft);
  return posts.map((post) => ({
    params: { slug: post.id },
    props: { post },
  }));
}

const { post } = Astro.props;
const { Content } = await render(post);
---

<Layout title={post.data.title} description={post.data.description}>
  <a href={withBase('/blog')} class="mono" style="font-size: 0.85rem; color: var(--text-muted);">&larr; Back to blog</a>
  <h1 style="margin: var(--space-3) 0 0.25rem;">{post.data.title}</h1>
  <p class="mono" style="color: var(--text-muted); font-size: 0.85rem; margin: 0 0 var(--space-4);">
    {post.data.date.toLocaleDateString('en-GB', { year: 'numeric', month: 'long', day: 'numeric' })}
  </p>
  <div style="margin-bottom: var(--space-6);">
    {post.data.tags.map((t: string) => <span class="tag">{t}</span>)}
  </div>
  <div class="prose" style="color: var(--text);">
    <Content />
  </div>
</Layout>

<style>
  .prose :global(p) {
    color: var(--text);
    line-height: 1.6;
  }
  .prose :global(h2),
  .prose :global(h3) {
    margin-top: 2rem;
  }
  .prose :global(code) {
    font-family: var(--font-mono);
    background: var(--bg-elevated);
    padding: 0.15rem 0.4rem;
    border-radius: 4px;
    font-size: 0.9em;
  }
  .prose :global(pre) {
    background: var(--bg-elevated);
    border: 1px solid var(--border);
    border-radius: 8px;
    padding: 1rem;
    overflow-x: auto;
  }
  .prose :global(a) {
    color: var(--accent);
  }
</style>
